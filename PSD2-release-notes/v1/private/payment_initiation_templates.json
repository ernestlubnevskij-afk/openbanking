{
    "openapi": "3.0.1",
    "info": {
        "title": "Private Payment Initiation Templates",
        "description": "Provides templates for private payment initiations. <br>Notes: The payment product scope will be increasing with time. The supported payment products are: <br>&emsp; - &emsp; private-se-domestic-own-credit-transfers <br>&emsp; - &emsp; private-se-domestic-credit-transfers <br>&emsp; - &emsp; private-sepa-credit-transfers <br>&emsp; - &emsp; private-se-domestic-alias-credit-transfers <br>For other private payment products please visit <a href=\"https://developer.sebgroup.com/products/psd2-payment-initiation/payment-initiation\">Link to V8</a><br>\n",
        "contact": {
            "email": "oasis@seb.se"
        },
        "version": "1.0.0",
        "x-seb": {
            "domain": "DOM15",
            "tribe": "TRI50",
            "art": "ART168",
            "team": "TEAM533"
        },
        "x-seb-api": {
            "id": "3c542126-b3a3-4af6-8743-6282369797ba",
            "accessibility": "open",
            "internal-routing-host": "payments"
        },
        "x-seb-portal": {
            "sandbox-uri": "https://api-sandbox.sebgroup.com/pis/private/v1/identified2",
            "production-uri": "https://tpp-api.sebgroup.com/tpp/pis/private/v1/identified2",
            "state": "active",
            "category": "servicing/cash management",
            "summary": "Payment Initiation",
            "release-date": "2026-03-16"
        }
    },
    "servers": [
        {
            "url": "https://api-sandbox.sebgroup.com/pis/private/v1/identified2",
            "description": "sandbox-uri"
        },
        {
            "url": "https://tpp-api.sebgroup.com/tpp/pis/private/v1/identified2",
            "description": "production-uri"
        }
    ],
    "paths": {
        "/templates": {
            "get": {
                "tags": [
                    "PSD2 Templates"
                ],
                "summary": "Provide a list of payment templates for the available payment products.",
                "description": "Access the template list endpoint to find all the supported payment products in the private payment initiation API. Use the template id in list to receive a partially filled-in payment initiation request. Fill in the template fields and submit it in the payments endpoint to initiate a payment. ",
                "operationId": "getAllTemplates",
                "parameters": [
                    {
                        "name": "Accept",
                        "in": "header",
                        "description": "Accepted content types.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "application/json",
                            "enum": [
                                "application/json"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A template list with descriptions of the payment products.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TemplateResponseDto"
                                },
                                "example": [
                                    {
                                        "templateId": "private-se-domestic-credit-transfers",
                                        "description": "The template supports transfers for private customers to a beneficiary account in another Swedish bank participating in Bankgirots dataclearing."
                                    },
                                    {
                                        "templateId": "private-se-domestic-own-credit-transfers",
                                        "description": "The template supports transfers for private customers between their own accounts in SEB."
                                    }
                                ]
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request <br>* Not including required input parameters, such as 'Accept' header. <br>* Specifying a payment that can not be signed, or does not exist in request body.",
                        "content": {
                            "application/problem+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseDto"
                                },
                                "example": {
                                    "type": "https://berlingroup.com/error-codes/FORMAT_ERROR",
                                    "title": "Text, maximum of 70 characters.",
                                    "detail": "Text, maximum of 500 characters.",
                                    "status": 400,
                                    "code": "FORMAT_ERROR"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
