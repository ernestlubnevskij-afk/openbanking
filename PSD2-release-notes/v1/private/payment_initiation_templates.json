                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseDto"
                                },
                                "example": {
                                    "type": "https://berlingroup.com/error-codes/FORMAT_ERROR",
                                    "title": "Text, maximum of 70 characters.",
                                    "detail": "Text, maximum of 500 characters.",
                                    "status": 403,
                                    "code": "CONSENT_UNKNOWN"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not found. <br>* Initiating signing for non-existent payment ID or payment product.<br>* Requesting incorrectly constructed URLs will return this error",
