                        }
                    }
                }
            }
        },
        "/templates/{templateId}": {
            "get": {
                "tags": [
                    "PSD2 Templates"
                ],
                "summary": "Returns the previously posted payment template.",
                "description": "Returns the request body of the previously posted payment template.",
                "operationId": "getTemplate",
                "parameters": [
                    {
                        "name": "templateId",
                        "in": "path",
                        "description": "Describes which payment product this call is in reference to. Needs to match whichever payment you are requesting information",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "private-se-domestic-credit-transfers",
                            "enum": [
                                "private-se-domestic-own-credit-transfers",
                                "private-se-domestic-credit-transfers",
                                "private-sepa-credit-transfers",
                                "private-se-domestic-alias-credit-transfers"
                            ]
                        }
                    },
                    {
                        "name": "Accept",
                        "in": "header",
                        "description": "Accepted content types.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "application/json",
                            "enum": [
                                "application/json"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A template that is partially filled-in.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TemplateBodyResponseDto"
                                },
                                "example": {
                                    "templateId": "Optional: private-se-domestic-credit-transfers",
                                    "instructedAmount": {
                                        "currency": "Required: SEK ISO 4217 standard format",
                                        "amount": "Required: Amount in SEK"
                                    },
                                    "debtorAccount": {
                                        "iban": "Conditional: Must be specified if bban not specified: Debtor account number in IBAN format",
                                        "bban": "Conditional: Must be specified if iban is not specified: Debtor account number in BBAN format: National account number"
                                    },
                                    "creditorAccount": {
                                        "iban": "Required: Creditor account number in IBAN format"
                                    },
                                    "debtorAccountMessage": "Optional: A message shown on debtor account statement, max 12 characters",
                                    "creditorName": "Required: Name of the creditor, max 140 characters",
                                    "remittanceInformationUnstructured": "Conditional: Must not be present if remittanceInformationStructured is used: Message to the beneficiary, max 140 characters",
                                    "remittanceInformationStructured": {
                                        "reference": "Free text for CINV or valid OCR for SCOR",
                                        "referenceType": "SCOR or CINV depending on reference type"
                                    },
                                    "requestedExecutionDate": "Conditional: Desired execution date in YYYY-MM-DD. This could only be sent when called with `payments` path variable e.g. POST /payments/{paymentProduct}",
                                    "startDate": "Conditional: Recurrent order that will start from specified date in format YYYY-MM-DD. Future day needs to be used. This could only be sent when called with `periodic-payments` path variable e.g. POST /periodic-payments/{paymentProduct}",
                                    "frequency": "Conditional: Recurrent order that can be repeated `monthly` only. This could only be sent when called with `periodic-payments` path variable e.g. POST /periodic-payments/{paymentProduct}"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request <br>* Not including required input parameters, such as 'Accept' header. <br>* Specifying a payment that can not be signed, or does not exist in request body.",
                        "content": {
                            "application/problem+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseDto"
                                },
                                "example": {
                                    "type": "https://berlingroup.com/error-codes/FORMAT_ERROR",
                                    "title": "Text, maximum of 70 characters.",
                                    "detail": "Text, maximum of 500 characters.",
                                    "status": 400,
                                    "code": "FORMAT_ERROR"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/problem+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseDto"
                                },
                                "example": {
                                    "type": "https://berlingroup.com/error-codes/FORMAT_ERROR",
                                    "title": "Text, maximum of 70 characters.",
                                    "detail": "Text, maximum of 500 characters.",
                                    "status": 401,
                                    "code": "CERTIFICATE_INVALID"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "content": {
