                    "503": {
                        "description": "Service unavailable. <br>* Returned when service is unavailable due to scheduled reasons, such as maintenance.",
                        "content": {
                            "application/problem+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseDto"
                                },
                                "example": {
                                    "type": "https://berlingroup.com/error-codes/FORMAT_ERROR",
                                    "title": "Text, maximum of 70 characters.",
                                    "detail": "Text, maximum of 500 characters.",
                                    "status": 503,
                                    "code": "Service unavailable"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "TemplateResponseDto": {
                "type": "object",
                "properties": {
                    "templateId": {
                        "type": "string",
                        "description": "Templates to be used for payment initiations for customers.",
                        "enum": [
                            "private-se-domestic-own-credit-transfers",
                            "private-se-domestic-credit-transfers",
                            "private-se-domestic-alias-credit-transfers",
                            "private-sepa-credit-transfers"
                        ]
                    },
                    "description": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Template description"
                    }
                }
            },
            "ErrorResponseDto": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "description": "A URI reference that identifies the problem type.",
                        "format": "uri"
                    },
                    "title": {
                        "type": "string",
                        "description": "Short human readable description of error type."
                    },
                    "detail": {
                        "type": "string",
                        "description": "Detailed human readable text specific to this instance of the error."
                    },
                    "status": {
                        "maximum": 599,
                        "minimum": 100,
                        "type": "integer",
                        "description": "The HTTP status code generated by the origin server for this occurrence of the problem.",
                        "format": "int32"
                    },
                    "code": {
                        "type": "string",
                        "description": "Message code to explain the nature of the underlying error."
                    }
                }
            },
            "CreditorAccount": {
                "type": "object",
                "properties": {
                    "iban": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Creditor account number in IBAN format"
                    },
                    "bgnr": {
                        "pattern": "^(?=^[0-9]+-[0-9]+$)[0-9-]{8,9}$|^[0-9]{7,8}",
                        "type": "string",
                        "description": "Creditor account number in Bankgiro format"
                    },
                    "pgnr": {
                        "pattern": "^(?=^[0-9]+-[0-9]+$)[0-9-]{3,9}$|^[0-9]{2,8}",
                        "type": "string",
                        "description": "Creditor account number in Plusgiro format"
                    }
                }
            },
            "DebtorAccount": {
                "type": "object",
                "properties": {
                    "iban": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Debtor account number in IBAN format"
                    },
                    "bban": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Debtor account number in BBAN format"
                    }
                }
            },
            "InstructedAmount": {
                "type": "object",
                "properties": {
                    "currency": {
                        "pattern": "^[A-Z]{3}$",
                        "type": "string",
                        "description": "Currency of the amount in ISO 4217 format"
                    },
                    "amount": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Amount to be instructed"
                    }
                }
            },
            "RemittanceInformationStructured": {
                "type": "object",
                "properties": {
                    "reference": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Free text for CINV or valid OCR for SCOR"
                    },
                    "referenceType": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "SCOR or CINV depending on reference type"
                    }
                }
            },
            "TemplateBodyResponseDto": {
                "type": "object",
                "properties": {
                    "templateId": {
                        "type": "string",
                        "description": "Templates to be used for payment initiations for customers.",
                        "enum": [
                            "private-se-domestic-own-credit-transfers",
                            "private-se-domestic-credit-transfers",
                            "private-se-domestic-alias-credit-transfers",
                            "private-sepa-credit-transfers"
                        ]
                    },
                    "instructedAmount": {
                        "$ref": "#/components/schemas/InstructedAmount"
                    },
                    "debtorAccount": {
                        "$ref": "#/components/schemas/DebtorAccount"
                    },
                    "debtorAccountMessage": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "A message shown on debtor account statement, max length depending on payment product."
                    },
                    "creditorAccount": {
                        "$ref": "#/components/schemas/CreditorAccount"
                    },
                    "creditorName": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Name of the creditor."
                    },
                    "requestedExecutionDate": {
                        "type": "string",
                        "description": "Requested execution date of transaction in format yyyy-mm-dd. If the date is not a valid bank date for the payment product, then the payment will be rejected.",
                        "format": "date"
                    },
                    "remittanceInformationUnstructured": {
                        "pattern": "^.+$",
                        "type": "string",
                        "description": "Message field to creditor."
                    },
                    "remittanceInformationStructured": {
                        "$ref": "#/components/schemas/RemittanceInformationStructured"
                    },
                    "startDate": {
                        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                        "type": "string",
                        "description": "The first applicable day of execution for the first generated transfer."
                    },
                    "frequency": {
                        "type": "string",
                        "description": "Only monthly recurrence is supported.",
                        "enum": [
                            "monthly"
                        ]
                    },
                    "instructionId": {
                        "type": "string"
                    },
                    "endToEndIdentification": {
                        "type": "string"
                    }
                }
            }
        }
    }
}